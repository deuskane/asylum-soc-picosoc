      logical_name : asylum

  gen_rv32i_user_asm_identity:
    generator : rvcc_gen
    parameters:
      file         : esw/user_identity.psm
      type         : pblazeide
      entity       : ROM_user
      cflags       : -Iesw/include --verbose
      logical_name : asylum
      
  gen_rv32i_user_c_identity_inverted:
    generator : rvcc_gen
    parameters:
      file         : esw/user_identity.c
      type         : c
      entity       : ROM_user
      cflags       : -Iesw/include --verbose -DINVERT_SWITCH
      logical_name : asylum

  gen_rv32i_user_c_identity:
    generator : rvcc_gen
    parameters:
      file         : esw/user_identity.c
      type         : c
      entity       : ROM_user
      cflags       : -Iesw/include --verbose
      logical_name : asylum

  gen_rv32i_user_c :
    generator : rvcc_gen
    parameters :
      file         : esw/user.c
      type         : c
      entity       : ROM_user
      cflags       : -Iesw/include --verbose
      logical_name : asylum

  gen_rv32i_user_c_uart_921600 :
    generator : rvcc_gen
    parameters :
      file         : esw/user.c
      type         : c
      entity       : ROM_user
      cflags       : -Iesw/include --verbose -DHAVE_UART -DCLOCK_FREQ=12500000 -DBAUD_RATE=921600
      logical_name : asylum

  gen_rv32i_user_c_uart_9600_spi :
    generator : rvcc_gen
    parameters :
      file         : esw/user.c
      type         : c
      entity       : ROM_user
      cflags       : -Iesw/include --verbose -DHAVE_UART -DCLOCK_FREQ=12500000 -DBAUD_RATE=9600 -DHAVE_SPI
