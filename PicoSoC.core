      type         : c
      entity       : ROM_user
      cflags       : -Iesw/include --verbose -DHAVE_UART -DCLOCK_FREQ=12500000 -DBAUD_RATE=921600 -DHAVE_SPI -DHAVE_SPI_MEMORY
      logical_name : asylum

  gen_rv32i_user_c_uart_9600_spi_mem :
    generator : rvcc_gen
    parameters :
      file         : esw/user.c
      type         : c
      entity       : ROM_user
      cflags       : -Iesw/include --verbose -DHAVE_UART -DCLOCK_FREQ=12500000 -DBAUD_RATE=9600 -DHAVE_SPI -DHAVE_SPI_MEMORY
